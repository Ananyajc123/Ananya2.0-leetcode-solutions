Algorithm
Convert n to long to handle Integer.MIN_VALUE.
If n is negative:
Replace x with 1/x.
Make n positive.
Recursively compute x^(n/2).
If n is even, return half * half.
If n is odd, return half * half * x.
Code
class Solution {
    public double myPow(double x, int n) {
        long N = n;

        if (N < 0) {
            x = 1 / x;
            N = -N;
        }

        return power(x, N);
    }

    private double power(double x, long n) {
        if (n == 0)
            return 1;

        double half = power(x, n / 2);

        if (n % 2 == 0)
            return half * half;
        else
            return half * half * x;
    }
}
