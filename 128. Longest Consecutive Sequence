Why This Is O(N)

Each number is visited at most:

once in outer loop
once in sequence expansion

So total work is linear.

Java Code
import java.util.*;

class Solution {
    public int longestConsecutive(int[] nums) {

        HashSet<Integer> set = new HashSet<>();

        // Add all elements to set
        for(int num : nums) {
            set.add(num);
        }

        int longest = 0;

        // Traverse through set
        for(int num : set) {

            // Start only if it is beginning
            if(!set.contains(num - 1)) {

                int currentNum = num;
                int count = 1;

                // Expand sequence
                while(set.contains(currentNum + 1)) {
                    currentNum++;
                    count++;
                }

                longest = Math.max(longest, count);
            }
        }

        return longest;
    }
}
